{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://creepwave-forge.local/contracts/handoff.schema.json",
  "title": "Creepwave Forge Role Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_role",
    "target_role",
    "goal",
    "scope",
    "confirmed",
    "decisions",
    "assumptions",
    "open_questions",
    "risks",
    "artifacts",
    "next_action"
  ],
  "properties": {
    "source_role": {
      "$ref": "#/$defs/role"
    },
    "target_role": {
      "$ref": "#/$defs/role"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "confirmed": {
      "$ref": "#/$defs/stringList"
    },
    "decisions": {
      "$ref": "#/$defs/stringList"
    },
    "assumptions": {
      "$ref": "#/$defs/stringList"
    },
    "open_questions": {
      "$ref": "#/$defs/stringList"
    },
    "risks": {
      "$ref": "#/$defs/stringList"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "type",
          "summary"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "requirements",
              "technical-design",
              "ui-ux-handoff",
              "backend-summary",
              "frontend-summary",
              "qa-plan",
              "qa-validation",
              "bug-investigation",
              "review-findings",
              "role-handoff",
              "release-notes",
              "other"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "role": {
      "type": "string",
      "enum": [
        "business-analyst",
        "ui-ux-designer",
        "solution-architect",
        "backend-engineer",
        "frontend-engineer",
        "qa-engineer",
        "bug-investigator",
        "code-reviewer",
        "handoff-writer",
        "context-router"
      ]
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
