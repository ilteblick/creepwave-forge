{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://creepwave-forge.local/contracts/handoff.schema.json",
  "title": "Creepwave Forge Role Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_role",
    "target_role",
    "goal",
    "scope",
    "confirmed",
    "decisions",
    "assumptions",
    "open_questions",
    "risks",
    "artifacts",
    "next_action"
  ],
  "properties": {
    "source_role": {
      "$ref": "#/$defs/role"
    },
    "target_role": {
      "$ref": "#/$defs/role"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "confirmed": {
      "$ref": "#/$defs/stringList"
    },
    "decisions": {
      "$ref": "#/$defs/stringList"
    },
    "assumptions": {
      "$ref": "#/$defs/stringList"
    },
    "open_questions": {
      "$ref": "#/$defs/stringList"
    },
    "risks": {
      "$ref": "#/$defs/stringList"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "artifact.schema.json"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "role": {
      "type": "string",
      "enum": [
        "backend-engineer",
        "bug-investigator",
        "business-analyst",
        "code-reviewer",
        "context-router",
        "frontend-engineer",
        "handoff-writer",
        "qa-engineer",
        "solution-architect",
        "ui-ux-designer"
      ]
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
